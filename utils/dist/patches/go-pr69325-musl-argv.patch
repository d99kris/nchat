+// readNullTerminatedStringsFromFile reads a file specified by the given path
+// and returns a slice of strings. Each string in the slice is null-terminated
+// in the file.
+//
+// Parameters:
+// - path: A null-terminated byte slice representing the file path.
+//
+// Returns:
+// - A slice of strings read from the file, where each string is null-terminated.
+//
+// It opens the file, reads its contents in chunks,
+// and parses the data into a slice of strings based on null-termination.
+//
+// Note: This function will return nil if the file cannot be opened.
+func readNullTerminatedStringsFromFile(path []byte) []string {
+	fd := open(&path[0], _O_RDONLY, 0)
+	if fd <= 0 {
+		return nil
+	}
+
+	// Read the file.
+	var data []byte
+	var buf [1024]byte
+	for {
+		n := read(fd, noescape(unsafe.Pointer(&buf[0])), int32(unsafe.Sizeof(buf)))
+		if n <= 0 { // EOF
+			break
+		}
+		data = append(data, buf[:n]...)
+	}
+
+	// Parse the data into a slice of strings.
+	var start int
+	var result = make([]string, 0, 8)
+	for i := 0; i < len(data); i++ {
+		if data[i] == 0 { // null-termination
+			result = append(result, gostring(&data[start:i][0]))
+			start = i + 1
+		}
+	}
+
+	closefd(fd)
+	return result
+}
+
+// godebugEnvBuf holds the contents of /proc/self/environ for the early
+// GODEBUG lookup on musl. It must be a global: getGodebugEarlyFromProc
+// runs before mallocinit, so the returned string aliases this buffer
+// instead of being heap-allocated.
+var godebugEnvBuf [16 << 10]byte
+
+// getGodebugEarlyFromProc returns the value of the GODEBUG environment
+// variable by reading /proc/self/environ, for musl-linux archive/library
+// builds where envp was not passed to the entry point. It is called
+// before mallocinit and therefore must not allocate.
+func getGodebugEarlyFromProc() string {
+	const prefix = "GODEBUG="
+	fd := open(&procEnviron[0], _O_RDONLY, 0)
+	if fd <= 0 {
+		return ""
+	}
+	total := 0
+	for total < len(godebugEnvBuf) {
+		n := read(fd, noescape(unsafe.Pointer(&godebugEnvBuf[total])), int32(len(godebugEnvBuf)-total))
+		if n <= 0 { // EOF
+			break
+		}
+		total += int(n)
+	}
+	closefd(fd)
+
+	buf := godebugEnvBuf[:total]
+	start := 0
+	for i := 0; i < len(buf); i++ {
+		if buf[i] == 0 { // null-termination
+			s := buf[start:i]
+			if len(s) > len(prefix) {
+				match := true
+				for j := 0; j < len(prefix); j++ {
+					if s[j] != prefix[j] {
+						match = false
+						break
+					}
+				}
+				if match {
+					// Null-terminated in buf, and buf is global,
+					// so a no-copy string is safe here.
+					return gostringnocopy(&buf[start+len(prefix)])
+				}
+			}
+			start = i + 1
+		}
+	}
+	return ""
 }
 
